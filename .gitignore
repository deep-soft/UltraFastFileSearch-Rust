# =============================================================================
# Rust / Cargo
# =============================================================================
debug/
target/
Cargo.lock
**/*.rs.bk
*.pdb
# macOS sed -i backup files
*.toml-e
*.yml-e
*.rs-e

# =============================================================================
# Trash / quarantine (local rollback staging)
# =============================================================================
/_trash/*
!/_trash/.gitignore
/_trash/**/.gitkeep
/_trash/**/.keep

# =============================================================================
# Build artifacts & generated binaries
# =============================================================================
build/
*.rlib
*.bin
/test_scf

# =============================================================================
# Logs, vendor, misc
# =============================================================================
/Shell/
# /LOG/ holds local-only runtime logs (defender ETLs, mental_health,
# pipeline `ship_run*.log` captures, etc.).  The one exception is
# `*CHANGELOG_HEALING.md` — per the operating-rules healing-log
# convention, these document each `just ship` iteration's failures
# and fixes and MUST ship with the commit that resolved them.  Git
# cannot re-include files inside an ignored *directory*, so the
# standard workaround is used: ignore the directory's *contents*
# (`/LOG/*`) and then un-ignore the healing logs by filename.
/LOG/*
!/LOG/*CHANGELOG_HEALING.md
/vendor/
/missing_paths.txt
/_trash/
/reference/
# Binaries are distributed via GitHub Releases, not committed to the repo
dist/
# Transient pipeline / debug logs captured at the workspace root via `tee`.
# Kept around between healing iterations but never committed.
/.ship_run*.log
/.clippy_run*.log
/.git_status.txt
/.git_show.txt
/.git_lsfiles.txt

