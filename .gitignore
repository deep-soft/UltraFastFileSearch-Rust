# =============================================================================
# Rust / Cargo
# =============================================================================
debug/
target/
Cargo.lock
**/*.rs.bk
*.pdb
# macOS sed -i backup files
*.toml-e
*.yml-e
*.rs-e

# =============================================================================
# Trash / quarantine (local rollback staging)
# =============================================================================
/_trash/*
!/_trash/.gitignore
/_trash/**/.gitkeep
/_trash/**/.keep

# =============================================================================
# Build artifacts & generated binaries
# =============================================================================
build/
*.rlib
*.bin
/test_scf

# =============================================================================
# Logs, vendor, misc
# =============================================================================
/Shell/
/LOG/
/vendor/
/missing_paths.txt
/_trash/
/reference/
# Binaries are distributed via GitHub Releases, not committed to the repo
dist/

# =============================================================================
# IDE / Editor / AI
# =============================================================================
.idea/
.vscode/
.ai/
.claude/
.qodo/
.reuse/
.windsurf/
*.iws
*.iml

# =============================================================================
# OS artifacts
# =============================================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
# macOS
.DS_Store
.AppleDouble
.LSOverride
# Linux
*~

# =============================================================================
# Environment and secrets
# =============================================================================
.env
*.env

# =============================================================================
# Cargo metadata & local-only cargo config
# =============================================================================
metadata.json
.cargo/macos.toml
.cargo/windows.toml
.cargo/.zshrc

# =============================================================================
# Internal dev docs (plans, audits, investigations — local only)
