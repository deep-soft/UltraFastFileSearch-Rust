# =============================================================================
# Rust / Cargo
# =============================================================================
debug/
target/
Cargo.lock
**/*.rs.bk
*.pdb

# =============================================================================
# Trash / quarantine (local rollback staging)
# =============================================================================
/_trash/*
!/_trash/.gitignore
/_trash/**/.gitkeep
/_trash/**/.keep

# =============================================================================
# Build artifacts
# =============================================================================
build/

# =============================================================================
# Distributable binaries
# Only the latest 2 versions are tracked in git.
# Older versions are purged from history. Use GitHub Releases for archival.
# =============================================================================
/Shell/
/LOG/
/vendor/
/missing_paths.txt
/_trash/
/reference/

# =============================================================================
# IDE / Editor
# =============================================================================
.idea/
.vscode/settings.json
*.iws
*.iml
.claude/

# =============================================================================
# OS artifacts
# =============================================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
# macOS
.DS_Store
.AppleDouble
.LSOverride
# Linux
*~

# =============================================================================
# Environment and secrets
# =============================================================================
.env
*.env

# =============================================================================
# Cargo metadata (machine-specific, auto-generated)
# =============================================================================
metadata.json

# =============================================================================
# Local-only spec/prompt files
# =============================================================================
INTENT_PROMPT.md
INTENT_PROMPT_V2.md
INTENT_SPEC_FAANG_CORE_INFRA.mdconsole
